{
  "mcpServers": {
    "xyce": {
      "type": "stdio",
      "command": "python3",
      "args": [
        "/absolute/path/to/analog-chip-design-agents/plugins/infrastructure/tools/mcp-adapter.py",
        "--wrapper",
        "/absolute/path/to/analog-chip-design-agents/plugins/infrastructure/tools/wrap-xyce.sh",
        "--tool",
        "xyce",
        "--description",
        "Xyce parallel SPICE / harmonic balance via output-filtering wrapper"
      ],
      "env": {
        "TOOL_TIMEOUT_S": "300"
      }
    }
  }
}
