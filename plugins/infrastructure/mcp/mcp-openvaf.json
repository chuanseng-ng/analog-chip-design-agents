{
  "mcpServers": {
    "openvaf": {
      "type": "stdio",
      "command": "python3",
      "args": [
        "/absolute/path/to/analog-chip-design-agents/plugins/infrastructure/tools/mcp-adapter.py",
        "--wrapper",
        "/absolute/path/to/analog-chip-design-agents/plugins/infrastructure/tools/wrap-openvaf.sh",
        "--tool",
        "openvaf",
        "--description",
        "OpenVAF Verilog-A -> OSDI compile via output-filtering wrapper"
      ],
      "env": {
        "TOOL_TIMEOUT_S": "300"
      }
    }
  }
}
