{
  "mcpServers": {
    "klayout": {
      "type": "stdio",
      "command": "python3",
      "args": [
        "/absolute/path/to/analog-chip-design-agents/plugins/infrastructure/tools/mcp-adapter.py",
        "--wrapper",
        "/absolute/path/to/analog-chip-design-agents/plugins/infrastructure/tools/wrap-klayout.sh",
        "--tool",
        "klayout",
        "--description",
        "KLayout DRC/LVS (batch) via output-filtering wrapper"
      ],
      "env": {
        "TOOL_TIMEOUT_S": "300"
      }
    }
  }
}
